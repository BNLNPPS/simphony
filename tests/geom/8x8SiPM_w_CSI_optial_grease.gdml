<?xml version="1.0" encoding="UTF-8" standalone="no" ?>
<gdml xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="http://service-spi.web.cern.ch/service-spi/app/releases/GDML/schema/gdml.xsd">

  <define>
    <!-- Loop variables -->
    <variable name="i" value="0"/>
    <variable name="j" value="0"/>
    
    <constant name="reflector_thickness" value="0.2"/>
    <constant name="pixel_width" value="2.0"/>
    <constant name="px" value="8"/>
    <constant name="py" value="8"/>
    <constant name="xtal_thickness" value="8.0"/>
    
    <constant name="sipm_size" value="2.0"/>
    <constant name="sipm_dead" value="0.2"/>
    <constant name="sipm_n" value="8"/>
    
    <constant name="pitch" value="2.2"/>
    
    <constant name="grease_thickness" value="0.1"/>
    <constant name="window_thickness" value="0.1"/>
    
    <!-- Optical indices -->
    <constant name="RI_crystal" value="1.82"/>
    <constant name="RI_grease" value="1.47"/>
    <constant name="RI_window" value="1.55"/>
    
    <!-- Total widths -->
    <constant name="xtal_array_width" value="17.4"/>
    <constant name="sipm_array_width" value="17.4"/>
    
    <!-- Starting positions -->
    <constant name="startXtalX" value="0.0"/>
    <constant name="startXtalY" value="0.0"/>
    <constant name="startSiPMX" value="-8.7"/>
    <constant name="startSiPMY" value="-8.7"/>
    
    <!-- Z positions -->
    <constant name="crystal_center_z" value="4.0"/>
    <constant name="grease_center_z" value="8.05"/>
    <constant name="window_center_z" value="8.15"/>
    <constant name="sipm_center_z" value="8.3"/>
    
    <!-- Optical properties -->
    <matrix coldim="2" name="RINDEX_CRYSTAL" values="1.0*eV 1.82 4.0*eV 1.82"/>
    <matrix coldim="2" name="RINDEX_GREASE" values="1.0*eV 1.47 4.0*eV 1.47"/>
    <matrix coldim="2" name="RINDEX_WINDOW" values="1.0*eV 1.55 4.0*eV 1.55"/>
    <matrix coldim="2" name="RINDEX_AIR" values="1.0*eV 1.0 4.0*eV 1.0"/>
    
    <!-- Absorption lengths (mm) -->
    <matrix coldim="2" name="ABSLENGTH_CRYSTAL" values="1.0*eV 400.0 4.0*eV 400.0"/>
    <matrix coldim="2" name="ABSLENGTH_GREASE" values="1.0*eV 1000.0 4.0*eV 1000.0"/>
    <matrix coldim="2" name="ABSLENGTH_WINDOW" values="1.0*eV 1000.0 4.0*eV 1000.0"/>
    <matrix coldim="2" name="ABSLENGTH_AIR" values="1.0*eV 10000.0 4.0*eV 10000.0"/>
    
    <!-- Scintillation properties -->
    <matrix coldim="2" name="SCINT_SPECTRUM" values="1.5*eV 0.0 2.896*eV 1.0 4.0*eV 0.0"/>
    
    <!-- Reemission probability  -->
    <matrix coldim="2" name="REEMISSIONPROB_CRYSTAL" values="1.0*eV 0.0 4.0*eV 0.0"/>
    
    <!-- Const properties for Geant4 11.x -->
    <matrix coldim="1" name="SCINT_YIELD_CONST" values="5000.0"/>
    <matrix coldim="1" name="RESOLUTION_SCALE" values="1.0"/>
    <matrix coldim="1" name="FAST_TIME_CONST" values="21.5"/>
    <matrix coldim="1" name="SLOW_TIME_CONST" value="43.8"/>
    <matrix coldim="1" name="YIELD_RATIO" value="0.87"/>
    
    <!-- Surface properties -->
    <matrix coldim="2" name="EFFICIENCY_0" values="1.0*eV 0.0 4.0*eV 0.0"/>
    <matrix coldim="2" name="EFFICIENCY_100" values="1.0*eV 1.0 4.0*eV 1.0"/>
    <matrix coldim="2" name="REFLECTIVITY_0" values="1.0*eV 0.0 4.0*eV 0.0"/>
    <matrix coldim="2" name="REFLECTIVITY_30" values="1.0*eV 0.3 4.0*eV 0.3"/>
    <matrix coldim="2" name="REFLECTIVITY_98" values="1.0*eV 0.98 4.0*eV 0.98"/>
  </define>

  <materials>
    <!-- Air -->
    <material name="Air" state="gas">
      <D unit="g/cm3" value="0.0012"/>
      <fraction n="0.7" ref="N"/>
      <fraction n="0.3" ref="O"/>
      <property name="RINDEX" ref="RINDEX_AIR"/>
      <property name="ABSLENGTH" ref="ABSLENGTH_AIR"/>
    </material>


    <material name="Crystal" state="solid">
      <D unit="g/cm3" value="4.51"/>
      <fraction n="1.0" ref="G4_CESIUM_IODIDE"/>
      <property name="RINDEX" ref="RINDEX_CRYSTAL"/>
      <property name="ABSLENGTH" ref="ABSLENGTH_CRYSTAL"/>
      
      <!-- Geant4 11.x style properties -->
      <property name="SCINTILLATIONYIELD" ref="SCINT_YIELD_CONST"/>
      <property name="RESOLUTIONSCALE" ref="RESOLUTION_SCALE"/>
      <property name="SCINTILLATIONCOMPONENT1" ref="SCINT_SPECTRUM"/>
      <property name="SCINTILLATIONCOMPONENT2" ref="SCINT_SPECTRUM"/>
      <property name="SCINTILLATIONTIMECONSTANT1" ref="FAST_TIME_CONST"/>
      <property name="SCINTILLATIONTIMECONSTANT2" ref="SLOW_TIME_CONST"/>
      <property name="SCINTILLATIONYIELD1" value="0.13"/>
      <property name="SCINTILLATIONYIELD2" value="0.87"/>
      
      <!-- Legacy properties for Opticks compatibility -->
      <property name="FASTCOMPONENT" ref="SCINT_SPECTRUM"/>
      <property name="SLOWCOMPONENT" ref="SCINT_SPECTRUM"/>
      <property name="FASTTIMECONSTANT" ref="FAST_TIME_CONST"/>
      <property name="SLOWTIMECONSTANT" ref="SLOW_TIME_CONST"/>
      <property name="YIELDRATIO" value="0.87"/>
      <property name="REEMISSIONPROB" ref="REEMISSIONPROB_CRYSTAL"/>
    </material>

    <material name="OpticalGrease" state="solid">
      <D unit="g/cm3" value="1.03"/>
      <fraction n="1.0" ref="G4_SILICON_DIOXIDE"/>
      <property name="RINDEX" ref="RINDEX_GREASE"/>
      <property name="ABSLENGTH" ref="ABSLENGTH_GREASE"/>
    </material>

    <material name="EntranceWindow" state="solid">
      <D unit="g/cm3" value="1.2"/>
      <fraction n="1.0" ref="G4_SILICON_DIOXIDE"/>
      <property name="RINDEX" ref="RINDEX_WINDOW"/>
      <property name="ABSLENGTH" ref="ABSLENGTH_WINDOW"/>
    </material>
  </materials>

  <solids>
    <!-- World -->
    <box name="WorldBox" x="100" y="100" z="100" lunit="mm"/>
    
    <!-- Crystal pixel -->
    <box name="CrystalPixel" x="2.0" y="2.0" z="8.0" lunit="mm"/>
    
    <!-- Optical grease layer -->
    <box name="GreaseLayer" x="17.4" y="17.4" z="0.1" lunit="mm"/>
    
    <!-- Entrance window -->
    <box name="WindowLayer" x="17.4" y="17.4" z="0.1" lunit="mm"/>
    
    <!-- SiPM active area -->
    <box name="SiPMActive" x="2.0" y="2.0" z="0.2" lunit="mm"/>
    
    <!-- SiPM dead spaces -->
    <box name="SiPMDeadH" x="17.4" y="0.2" z="0.2" lunit="mm"/>
    <box name="SiPMDeadV" x="0.2" y="2.0" z="0.2" lunit="mm"/>
    
    <!-- Optical surfaces -->
    
    <!-- FIN1: DETECT surface (100% QE) -->
    <opticalsurface name="DetectorSurface" type="dielectric_dielectric" 
                   finish="polished" model="glisur" value="1">
      <property name="REFLECTIVITY" ref="REFLECTIVITY_0"/>
      <property name="EFFICIENCY" ref="EFFICIENCY_100"/>
    </opticalsurface>
    
    <!-- FIN2 & FIN6: Crystal surfaces (POLISH, 0.98RC) -->
    <opticalsurface name="CrystalSurface" type="dielectric_dielectric" 
                   finish="polished" model="glisur" value="1">
      <property name="REFLECTIVITY" ref="REFLECTIVITY_98"/>
      <property name="EFFICIENCY" ref="EFFICIENCY_0"/>
    </opticalsurface>
    
    <!-- FIN4: MPPC dead space (METAL, 0.3RC) -->
    <opticalsurface name="DeadSurface" type="dielectric_dielectric" 
                   finish="polished" model="glisur" value="1">
      <property name="REFLECTIVITY" ref="REFLECTIVITY_30"/>
      <property name="EFFICIENCY" ref="EFFICIENCY_0"/>
    </opticalsurface>
    
    <!-- FIN5: Smooth coupling surface (POLISH) -->
    <!-- Used for grease and window side surfaces -->
    <opticalsurface name="CouplingSurface" type="dielectric_dielectric" 
                   finish="polished" model="glisur" value="1">
      <property name="REFLECTIVITY" ref="REFLECTIVITY_0"/>
      <property name="EFFICIENCY" ref="EFFICIENCY_0"/>
    </opticalsurface>
  </solids>

  <structure>
    <!-- ========== VOLUME DEFINITIONS ========== -->
    
    <!-- SiPM Active Area Volume -->
    <volume name="SiPMActiveVol">
      <materialref ref="EntranceWindow"/>
      <solidref ref="SiPMActive"/>
      <auxiliary auxtype="SensDet" auxvalue="SD0"/>
      <auxiliary auxtype="SensorSurface" auxvalue="DetectorSurface"/>
      <auxiliary auxtype="OpticalSurface" auxvalue="DetectorSurface"/>
      <auxiliary auxtype="Optical" auxvalue="1"/>
      <auxiliary auxtype="GroupName" auxvalue="SiPMActive"/>
    </volume>
    
    <!-- SiPM Dead Space Volumes -->
    <volume name="SiPMDeadHVol">
      <materialref ref="EntranceWindow"/>
      <solidref ref="SiPMDeadH"/>
      <auxiliary auxtype="OpticalSurface" auxvalue="DeadSurface"/>
      <auxiliary auxtype="Optical" auxvalue="1"/>
      <auxiliary auxtype="GroupName" auxvalue="SiPMDead"/>
    </volume>
    
    <volume name="SiPMDeadVVol">
      <materialref ref="EntranceWindow"/>
      <solidref ref="SiPMDeadV"/>
      <auxiliary auxtype="OpticalSurface" auxvalue="DeadSurface"/>
      <auxiliary auxtype="Optical" auxvalue="1"/>
      <auxiliary auxtype="GroupName" auxvalue="SiPMDead"/>
    </volume>
    
    <!-- Crystal Pixel Volume -->
    <volume name="CrystalPixelVol">
      <materialref ref="Crystal"/>
      <solidref ref="CrystalPixel"/>
      <auxiliary auxtype="Optical" auxvalue="1"/>
      <auxiliary auxtype="GroupName" auxvalue="CrystalPixels"/>
      <!-- NO SkinSurface here - applied globally below -->
    </volume>
    
    <!-- Optical Grease Volume -->
    <volume name="GreaseVol">
      <materialref ref="OpticalGrease"/>
      <solidref ref="GreaseLayer"/>
      <auxiliary auxtype="Optical" auxvalue="1"/>
    </volume>
    
    <!-- Entrance Window Volume -->
    <volume name="WindowVol">
      <materialref ref="EntranceWindow"/>
      <solidref ref="WindowLayer"/>
      <auxiliary auxtype="Optical" auxvalue="1"/>
    </volume>
    
    <!-- World Volume -->
    <volume name="WorldLog">
      <materialref ref="Air"/>
      <solidref ref="WorldBox"/>
      <auxiliary auxtype="Optical" auxvalue="1"/>
      
      <!-- Grease Layer -->
      <physvol name="GreaseLayer">
        <volumeref ref="GreaseVol"/>
        <position name="grease_pos" x="0" y="0" z="8.05" unit="mm"/>
      </physvol>
      
      <!-- Entrance Window -->
      <physvol name="WindowLayer">
        <volumeref ref="WindowVol"/>
        <position name="window_pos" x="0" y="0" z="8.15" unit="mm"/>
      </physvol>
      
      <!-- 8x8 Crystal Array -->
      <loop for="i" from="0" to="7" step="1">
        <loop for="j" from="0" to="7" step="1">
          <physvol name="Crystal_{i}_{j}">
            <volumeref ref="CrystalPixelVol"/>
            <position name="crystal_pos_{i}_{j}"
                      x="-8.7 + i*2.2"
                      y="-8.7 + j*2.2"
                      z="4.0"
                      unit="mm"/>
          </physvol>
        </loop>
      </loop>
      
      <!-- 8x8 SiPM Array -->
      <loop for="i" from="0" to="7" step="1">
        <loop for="j" from="0" to="7" step="1">
          <physvol name="SiPM_{i}_{j}">
            <volumeref ref="SiPMActiveVol"/>
            <position name="sipm_pos_{i}_{j}"
                      x="-8.7 + i*2.2"
                      y="-8.7 + j*2.2"
                      z="8.3"
                      unit="mm"/>
          </physvol>
        </loop>
      </loop>
      
      <!-- Vertical Dead Spaces -->
      <loop for="i" from="0" to="7" step="1">
        <loop for="j" from="0" to="6" step="1">
          <physvol name="SiPMDeadV_{i}_{j}">
            <volumeref ref="SiPMDeadVVol"/>
            <position name="deadV_pos_{i}_{j}"
                      x="-8.7 + i*2.2 + 1.1"
                      y="-8.7 + j*2.2"
                      z="8.3"
                      unit="mm"/>
          </physvol>
        </loop>
      </loop>
      
      <!-- Horizontal Dead Spaces -->
      <loop for="i" from="0" to="6" step="1">
        <physvol name="SiPMDeadH_{i}">
          <volumeref ref="SiPMDeadHVol"/>
          <position name="deadH_pos_{i}"
                    x="0"
                    y="-8.7 + i*2.2 + 1.1"
                    z="8.3"
                    unit="mm"/>
        </physvol>
      </loop>
    </volume>

    <!-- ========== SKIN SURFACES ========== -->
    
    <skinsurface name="SiPMActiveSkin" surfaceproperty="DetectorSurface">
      <volumeref ref="SiPMActiveVol"/>
    </skinsurface>
    
    <skinsurface name="CrystalSkin" surfaceproperty="CrystalSurface">
      <volumeref ref="CrystalPixelVol"/>
    </skinsurface>
    
    <skinsurface name="DeadSkinH" surfaceproperty="DeadSurface">
      <volumeref ref="SiPMDeadHVol"/>
    </skinsurface>
    
    <skinsurface name="DeadSkinV" surfaceproperty="DeadSurface">
      <volumeref ref="SiPMDeadVVol"/>
    </skinsurface>
  </structure>

  <setup name="Default" version="1.0">
    <world ref="WorldLog"/>
  </setup>
</gdml>
