{
  "name": "simphony",
  "image": "ghcr.io/bnlnpps/simphony:base",
  "features": {
    "ghcr.io/devcontainers/features/github-cli:1": {},
    "./features/llvm": {
      "version": "23"
    }
  },
  "mounts": [
    "source=${localEnv:HOME}/.codex,target=/root/.codex,type=bind"
  ],
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-vscode.cpptools",
        "ms-vscode.cmake-tools",
        "openai.chatgpt"
      ]
    }
  }
}
